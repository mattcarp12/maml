fn get_slice(cond bool) []int {
    a := [1, 2, 3]
    b := [4, 5, 6]
    
    if (cond) {
        return a[:]
    }
    
    return b[:]
}

fn main() int {
    mut sum := 0
    
    for (mut i := 0; i < 5; i = i + 1) {
        // i=0: 1
        // i=1: 4
        // i=2: 1
        // i=3: 4
        // i=4: 1
        // sum = 11
        
        is_even := (i % 2) == 0
        s := get_slice(is_even)
        sum = sum + s[0]
    }
    
    return sum
}
// EXIT_CODE: 146

fn add(x int, y int) int {
    return x + y
}

fn complex_math_and_assign() int {
    mut a := 5
    mut b := 10
    a = (a * 2) + b + 3
    return a
}

fn main() int {
    mut score := 10 * 2 - 4 / 2 + 5
    mut x := 42
    if true {
        x := 99
        score = add(score, x)
    }
    score = add(score, complex_math_and_assign())

    val := if score > 100 {
        => 1
    } else {
        => 0
    }

    if false {
        return 999
    }

    return score + val
}
// EXIT_CODE: 90

type Box = { id int, data View<int> }

fn get_slice(cond bool) View<int> {
    a := [3]int{1, 2, 3}
    b := [3]int{4, 5, 6}
    if cond { return a[:] }
    return b[:]
}

fn consume(own s View<int>) int {
    return s[2]
}

fn make_box(id int) Box {
    arr := [3]int{10, 20, 30}
    return Box{id: id, data: arr[:]}
}

fn main() int {
    mut sum := 0

    for mut i := 0; i < 5; i = i + 1 {
        s := get_slice((i % 2) == 0)
        sum = sum + s[0]
    }

    b := make_box(42)
    sum = sum + b.data[1] + b.id

    arr1 := [3]int{5, 10, 15}
    sum = sum + consume(own arr1[:])

    mut active := make_box(10).data
    for mut i := 0; i < 3; i = i + 1 {
        temp := [3]int{i, i+1, i+2}[:]
        active = temp
    }

    return sum + active[0]
}
fn validate_age(age int) Result<int, string> {
	return if (age < 0) {
		=> Err("negative")
	} else {
		=> if (age < 18) {
			=> Err("underage")
		} else {
			=> Ok(age)
		}
	}
}

fn main() int {
	res1 := validate_age(20)
	res2 := validate_age(15)
	res3 := validate_age(-5)

	v1 := match res1 {
		case Ok(val) { => val }
		case Err(msg) { => 0 }
	}

	v2 := match res2 {
		case Ok(val) { => val }
		case Err(msg) { => 1 }
	}

	v3 := match res3 {
		case Ok(val) { => val }
		case Err(msg) { => 2 }
	}

	return v1 + v2 + v3
}

// Tests boolean logic, prefix negation, and short-circuiting
fn main() int {
    mut score := 0
    
    // Should execute
    if (true || false) {
        score = score + 10
    }
    
    // Should execute (!false is true)
    if (!false && true) {
        score = score + 5
    }
    
    // Should NOT execute (short-circuits on false)
    if (false && true) {
        score = score - 100
    }
    
    return score // Should exit with status 15
}
// EXPECTED_OUTPUT: world

fn main() int {
    arr := [5]int{10, 20, 30, 40, 50}
    mut slice := arr[1:4]
    x := slice[0]
    slice[2] = 99

    s := "hello"
    ch1 := s[1]
    ch2 := s[4]

    greetings := [3]string{"hello", "world", "!"}
    puts(greetings[1])

    return x + arr[3] + ch1 + ch2
}
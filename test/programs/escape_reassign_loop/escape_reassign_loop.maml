fn make_array(v int) []int {
    arr := [v, v+1, v+2]
    return arr[:]
}

fn main() int {
    // Escapes from make_array, lands in main's heap ARC tracker
    mut active := make_array(10)
    
    for (mut i := 0; i < 3; i = i + 1) {
        // Creates a new heap array, reassigns it. 
        // The previous array must be released gracefully when overwritten or when the block ends.
        temp := make_array(i)
        active = temp
    }
    
    // The last active array was make_array(2), so active[0] == 2
    return active[0] 
}
fn divide(a int, b int) Option<int> {
	return if (b == 0) {
		=> None
	} else {
		=> Some(a / b)
	}
}

fn compute(x int) Option<int> {
	return match divide(100, x) {
		case Some(val) {
			=> match divide(val, 2) {
				case Some(res) { => Some(res) }
				case _ { => None }
			}
		}
		case _ { => None }
	}
}

fn main() int {
	s1 := compute(10)
	s2 := compute(0)

	r1 := match s1 {
		case Some(v) { => v }
		case None { => 0 }
	}

	r2 := match s2 {
		case Some(v) { => v }
		case None { => 10 }
	}

	return r1 + r2
}

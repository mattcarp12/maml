async fn background_ticker() {
    print("Ticker: Tick 1")
    yield_now() 
    print("Ticker: Tick 2")
    yield_now()
    print("Ticker: Tick 3 (Done)")
}

async fn get_data() int {
    print("GetData: Starting computation...")
    yield_now()
    print("GetData: Finished computation!")
    return 42
}

async fn async_main() {
    print("Main: Spawning ticker (detached)")
    spawn background_ticker() 

    print("Main: Spawning get_data")
    data_handle := spawn get_data()

    print("Main: Awaiting data...")
    result := await data_handle

    // Assuming print supports integer formatting, or just print strings to test control flow first
    print("Main: Got result!") 
}

fn main() int {
    s := spawn async_main()
    run_executor(s)
    return 99
}
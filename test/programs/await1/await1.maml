async fn fetch_user_data() int {
    puts("Fetching data...")
    // await network_call()
    return 42
}

// OS Entrypoint
fn main() int {
    // 1. Manually instantiate the root task
    root_task := fetch_user_data()
    
    // 2. Spawn it into the runtime queue
    spawn(root_task)
    
    // 3. Boot the executor to process the queue!
    return run_executor() 
}
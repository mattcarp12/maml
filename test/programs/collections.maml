// EXIT_CODE: 185

fn main() int {
    mut m := Map<string, int>{}
    m["hello"] = 50
    m["world"] = 60
    m["hello"] = 999

    mut v := Vec<int>{}
    for mut i := 0; i < 20; i = i + 1 {
        v << i * 10
    }

    return m["hello"] + m["world"] + v[15]
    // return value is 1209
    // exit code = 1209 % 256 = 185
}
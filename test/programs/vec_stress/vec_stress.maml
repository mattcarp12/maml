fn read_element(s []int, idx int) int {
    return s[idx]
}

fn main() int {
    v := Vec<int>()
    
    // Push 20 items to trigger multiple maml_vec_grow allocations
    for (mut i := 0; i < 20; i = i + 1) {
        v.push(i)
    }
    
    // Pass v into a slice parameter to assert your implicit coercion pass works
    return read_element(v, 15)
}
